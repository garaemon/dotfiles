#!/bin/bash
# git-select: Interactively select a branch with peco and checkout.
# Place this script in your PATH to use as `git select`.
set -euo pipefail

show_help() {
  cat << 'EOF'
Usage: git select [OPTIONS]

Interactively select a branch with peco and checkout.
By default, shows local branches and open pull request branches together.

Options:
  -a        Show all branches including remote branches (without PR info)
  -h        Show this help message
EOF
}

show_all=false

while getopts "ha" opt; do
  case "${opt}" in
    h) show_help; exit 0 ;;
    a) show_all=true ;;
    *) show_help; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

if ! command -v peco &> /dev/null; then
  echo "Error: 'peco' command not found." >&2
  exit 1
fi

if [ "$show_all" = true ]; then
  selected_branch=$(git branch --all | sed 's/^[* ]*//' | sed 's/^ *//' | peco --prompt "checkout branch>")

  if [ -z "$selected_branch" ]; then
    echo "No branch selected." >&2
    exit 1
  fi

  selected_branch="${selected_branch#remotes/*/}"

  echo "Checking out '${selected_branch}'..."
  git checkout "$selected_branch"
  exit 0
fi

# Build a combined list of local branches and open PR branches.
# Local branches are shown as-is; PR branches include PR number and title.

local_branches=$(git branch --list | sed 's/^[* ]*//' | sed 's/^ *//')

# Collect PR info from gh if available
pr_lines=""
if command -v gh &> /dev/null; then
  pr_lines=$(gh pr list --state open --json number,headRefName,title \
    --template '{{range .}}{{.number}}	{{.headRefName}}	{{.title}}{{"\n"}}{{end}}' 2>/dev/null || true)
fi

# Format local branches, annotating with PR info if the branch has an open PR
candidates=""
used_pr_branches=""
while IFS= read -r branch; do
  [ -z "$branch" ] && continue
  pr_match=""
  if [ -n "$pr_lines" ]; then
    pr_match=$(printf '%s\n' "$pr_lines" | awk -F'\t' -v b="$branch" '$2 == b {print "(#" $1 "  " $3 ")"; exit}')
  fi
  if [ -n "$pr_match" ]; then
    candidates="${candidates}${branch} ${pr_match}"$'\n'
    used_pr_branches="${used_pr_branches}${branch}"$'\n'
  else
    candidates="${candidates}${branch}"$'\n'
  fi
done <<< "$local_branches"

# Add remaining PR branches (remote-only, not checked out locally)
if [ -n "$pr_lines" ]; then
  while IFS=$'\t' read -r number branch title; do
    [ -z "$branch" ] && continue
    if ! printf '%s\n' "$used_pr_branches" | grep -qx "$branch"; then
      candidates="${candidates}${branch} (#${number}  ${title})"$'\n'
    fi
  done <<< "$pr_lines"
fi

selected=$(echo -n "$candidates" | peco --prompt "checkout branch>")

if [ -z "$selected" ]; then
  echo "No branch selected." >&2
  exit 1
fi

# Extract branch name (everything before the optional PR annotation)
selected_branch="${selected% (#*}"

# If the branch doesn't exist locally, fetch it from origin first
if ! git show-ref --verify --quiet "refs/heads/${selected_branch}"; then
  echo "Fetching '${selected_branch}' from origin..."
  git fetch origin "${selected_branch}"
fi

echo "Checking out '${selected_branch}'..."
git checkout "$selected_branch"
